# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.err.log
*.out.log
debug.txt
git_log.txt
tsc_errors.txt
_temp_*.txt

# local runtime / scratch output
/.tmp/
/.codex-temp/
/.codex-*.log
/.next-dev-*.log

# local Codex / agent workspace metadata
/.agents/
/.codex/

# local-only internal notes, specs, and manual test plans
/docs/internal/
/docs/**/*draft*.md
/docs/**/*scratch*.md
/paapan_business_simulation.html

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
