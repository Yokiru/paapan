# Core app
NEXT_PUBLIC_SITE_URL=https://paapan.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GEMINI_API_KEY=your-gemini-api-key

# Feedback / support email
FEEDBACK_INBOX=hello@paapan.com
FEEDBACK_SENDER_NAME=Paapan Feedback
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=hello@paapan.com
ZOHO_SMTP_PASS=your-zoho-smtp-app-password

# Admin / internal ops
ADMIN_EMAIL_ALLOWLIST=admin1@example.com,admin2@example.com
CRON_SECRET=replace-with-long-random-secret

# Sharing / signing
# Prefer setting PAAPAN_SHARE_SECRET in production so share token signing does not
# depend on SUPABASE_SERVICE_ROLE_KEY.
PAAPAN_SHARE_SECRET=replace-with-long-random-secret

# Legacy fallback supported by lib/workspaceSharing.ts
# SHARE_LINK_SECRET=replace-with-long-random-secret
